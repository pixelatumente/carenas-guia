---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Página no encontrada | Carenas Guía">
  <Header />
  <main class="mx-auto grid min-h-[60vh] max-w-3xl place-items-center px-5 py-20 text-center">
    <div>
      <p class="text-sm font-black uppercase tracking-[0.24em]" style="color: var(--badge-text);">404</p>
      <h1 class="mt-4 text-4xl font-black tracking-tight" style="color: var(--text);">No encontramos esta página.</h1>
      <p class="mt-4 leading-7" style="color: var(--text-secondary);">Puede que la ficha todavía no esté publicada o que el enlace tenga un error.</p>
      <div class="mt-8 flex justify-center gap-3">
        <a href="/" class="btn btn-primary">Volver al inicio</a>
        <a href="/mapa/" class="btn btn-soft">Ver mapa</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
