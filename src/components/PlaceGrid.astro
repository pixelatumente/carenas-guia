---
import PlaceCard from './PlaceCard.astro';

interface Props {
  places: any[];
  emptyText?: string;
}

const { places, emptyText = 'Todavía no hay fichas publicadas en esta sección.' } = Astro.props;
---

{places.length > 0 ? (
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {places.map((place) => (
      <PlaceCard place={place} />
    ))}
  </div>
) : (
  <div class="card p-8 text-center">
    <p class="text-lg font-bold" style="color: var(--text);">Esta sección está pendiente de datos.</p>
    <p class="mt-2 text-sm leading-6" style="color: var(--text-secondary);">{emptyText}</p>
  </div>
)}
