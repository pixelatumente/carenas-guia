---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mx-auto mb-8 max-w-3xl text-center md:mb-12">
  {eyebrow && <p class="mb-3 text-sm font-black uppercase tracking-[0.24em]" style="color: var(--badge-text);">{eyebrow}</p>}
  <h2 class="text-3xl font-black tracking-tight md:text-5xl" style="color: var(--text);">{title}</h2>
  {description && <p class="mt-4 text-lg leading-8" style="color: var(--text-secondary);">{description}</p>}
</div>
