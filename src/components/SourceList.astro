---
interface Props {
  urls?: string[];
}

const { urls = [] } = Astro.props;
---

{urls.length > 0 && (
  <div class="rounded-2xl p-5" style="border: 1px solid var(--line); background: var(--surface-muted);">
    <h3 class="text-sm font-black uppercase tracking-[0.18em]" style="color: var(--text-secondary);">Fuentes consultadas</h3>
    <ul class="mt-3 space-y-2">
      {urls.map((url) => (
        <li>
          <a href={url} target="_blank" rel="noopener noreferrer" class="break-words text-sm font-bold hover:underline" style="color: var(--badge-text);">
            {url}
          </a>
        </li>
      ))}
    </ul>
  </div>
)}
