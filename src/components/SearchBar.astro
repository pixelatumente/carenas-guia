---
interface Props {
  items: any[];
}

const { items } = Astro.props;
---

<div class="relative mx-auto max-w-2xl">
  <label for="site-search" class="mb-2.5 block text-xs font-black uppercase tracking-[0.2em]" style="color: var(--text-secondary);">
    Buscar por nombre
  </label>
  <input
    id="site-search"
    type="search"
    autocomplete="off"
    placeholder="Escribe el nombre de un lugar..."
    class="search-input"
  />
  <div id="search-results" class="sr-results" hidden></div>
</div>

<script type="application/json" id="search-data" set:html={JSON.stringify(items)}></script>
<script>
  const DATA = JSON.parse(document.getElementById('search-data')?.textContent || '[]');
  const input = document.getElementById('site-search');
  const results = document.getElementById('search-results');

  function escapeHtml(value) {
    const div = document.createElement('div');
    div.textContent = String(value || '');
    return div.innerHTML;
  }

  function render(value) {
    const query = value.trim().toLowerCase();
    if (!query) {
      results.hidden = true;
      results.innerHTML = '';
      return;
    }

    const matches = DATA
      .filter((item) => item.title.toLowerCase().includes(query))
      .slice(0, 8);

    if (!matches.length) {
      results.hidden = false;
      results.innerHTML = '<div class="p-4 text-sm font-bold" style="color:var(--text-secondary)">No encontramos resultados con ese nombre.</div>';
      return;
    }

    results.hidden = false;
    results.innerHTML = matches
      .map((item) => `
        <a class="sr-item" href="${item.url}">
          <span class="sr-title">${escapeHtml(item.title)}</span>
        </a>
      `)
      .join('');
  }

  input.addEventListener('input', (event) => render(event.target.value));
  document.addEventListener('click', (event) => {
    if (!event.target.closest('.relative')) {
      results.hidden = true;
    }
  });
</script>
