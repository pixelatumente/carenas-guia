---
import { initials } from '../lib/utils';
import { getPhoto } from '../lib/photos';

interface Props {
  place: any;
  compact?: boolean;
}

const { place, compact = false } = Astro.props;
const cover = place.image || getPhoto(place.slug);
---

<a
  href={`/lugares/${place.slug}/`}
  class="group block h-full rounded-[1.5rem] p-5 shadow-sm transition hover:-translate-y-1"
  style="border: 1px solid var(--line); background: var(--surface); box-shadow: var(--shadow-card);"
>
  {cover ? (
    <img
      src={cover}
      alt={place.imageAlt || place.name}
      loading="lazy"
      decoding="async"
      class="mb-5 h-44 w-full rounded-2xl object-cover"
    />
  ) : (
    <div class="mb-5 grid h-44 place-items-center rounded-2xl text-5xl font-black tracking-tight" style="background: linear-gradient(135deg, rgba(20,184,166,0.08), transparent, rgba(245,158,11,0.08)); color: var(--badge-text);">
      {initials(place.name)}
    </div>
  )}

  <div class="flex items-start justify-between gap-4">
    <h3 class="text-xl font-black tracking-tight" style="color: var(--text); transition: color 160ms;">{place.name}</h3>
    <span class="badge shrink-0">{place.type}</span>
  </div>

  <p class="mt-3 text-sm leading-6" style="color: var(--text-secondary);">
    {place.short}
  </p>

  {!compact && place.tags?.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {place.tags.slice(0, 3).map((tag: string) => (
        <span class="rounded-full px-3 py-1 text-xs font-bold" style="background: var(--tag-bg); color: var(--tag-text);">
          {tag}
        </span>
      ))}
    </div>
  )}

  <div class="mt-5 flex items-center justify-between pt-4" style="border-top: 1px solid var(--line);">
    <span style="color: var(--badge-text);" class="text-sm font-bold">Ver ficha</span>
    <span class="text-2xl leading-none transition group-hover:translate-x-1" style="color: var(--text-muted);">→</span>
  </div>
</a>
