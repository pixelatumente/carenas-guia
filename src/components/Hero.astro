---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryText: string;
  primaryHref: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const { eyebrow, title, description, primaryText, primaryHref, secondaryText, secondaryHref } = Astro.props;
---

<section class="relative overflow-hidden rounded-[2rem] bg-slate-950 px-6 py-16 text-white shadow-2xl shadow-slate-950/10 md:px-10 md:py-24">
  <div class="absolute inset-0 opacity-30" aria-hidden="true">
    <div class="absolute -left-24 top-0 h-72 w-72 rounded-full bg-teal-400 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-80 w-80 rounded-full bg-amber-300 blur-3xl"></div>
    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(15,23,42,0.92),rgba(15,118,110,0.62))]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-3xl">
    {eyebrow && <p class="mb-5 text-sm font-black uppercase tracking-[0.28em] text-teal-100">{eyebrow}</p>}
    <h1 class="text-4xl font-black tracking-tight text-white md:text-6xl">{title}</h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-100">{description}</p>

    <div class="mt-9 flex flex-col gap-3 sm:flex-row">
      <a href={primaryHref} class="btn btn-primary">{primaryText}</a>
      {secondaryText && secondaryHref && (
        <a href={secondaryHref} class="btn btn-ghost">{secondaryText}</a>
      )}
    </div>
  </div>
</section>
